APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://chatbotapp-production-d5b3.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chatbot_db
DB_USERNAME=root
DB_PASSWORD=

DOCSBOT_API_KEY=
DOCSBOT_BOT_ID=
DOCSBOT_TEAM_ID=

# =====================================================
# SESSION & CORS - Wajib dikonfigurasi di Railway!
# =====================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Kosongkan SESSION_DOMAIN untuk Railway agar tidak ada konflik cookie
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
# 'none' wajib jika frontend & backend beda domain di Railway
SESSION_SAME_SITE=none

# URL frontend Railway kamu — WAJIB diisi!
FRONTEND_URL=https://frontendapp-production-3259.up.railway.app

# Domain yang boleh pakai Sanctum stateful (pisah dengan koma, tanpa https://)
SANCTUM_STATEFUL_DOMAINS=frontendapp-production-3259.up.railway.app,chatbotapp-production-d5b3.up.railway.app

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
